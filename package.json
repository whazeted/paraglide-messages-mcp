{
	"name": "paraglide-messages-mcp",
	"version": "0.1.0",
	"description": "MCP server for translating Paraglide JS / inlang projects in validated per-locale batches — built for one agent per locale in parallel",
	"license": "MIT",
	"mcpName": "io.github.weshaze/paraglide-messages-mcp",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/WesHaze/paraglide-mcp.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"packageManager": "pnpm@10.33.2",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"bin": {
		"paraglide-messages-mcp": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist",
		"skill",
		"README.md"
	],
	"keywords": [
		"mcp",
		"model-context-protocol",
		"paraglide",
		"inlang",
		"i18n",
		"translation"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --exclude 'test/e2e.test.ts' --exclude 'test/benchmark*.test.ts'",
		"test:e2e": "pnpm build && vitest run test/e2e.test.ts",
		"test:all": "pnpm build && vitest run --exclude 'test/benchmark*.test.ts'",
		"bench": "vitest run test/benchmark.test.ts",
		"bench:subagents": "vitest run test/benchmark-subagents.test.ts",
		"bench:quality": "vitest run test/benchmark-quality.test.ts",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"flat": "^6.0.1",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@anthropic-ai/sdk": "^0.74.0",
		"@google/genai": "^2.8.0",
		"@types/node": "^22.0.0",
		"openai": "^6.42.0",
		"typescript": "^5.7.0",
		"vitest": "^3.2.0"
	}
}
